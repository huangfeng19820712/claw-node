# ClawNode 配置文件
# 放置于: ~/.clawnode/config.env

# ============ 基础配置 ============
# 默认工作目录（CLI 模式下的工作目录）
WORKDIR=E:/fwwork/javaws

# OpenClaw 服务器地址（仅节点服务模式需要）
OPENCLAW_URL=http://localhost:3000

# 节点标识（仅节点服务模式需要）
NODE_ID=node-001

# 节点密钥（仅节点服务模式需要）
NODE_SECRET=your-secret-key

# ============ 飞书配置 ============
# 飞书应用凭证（用于下载附件）
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxx

# ============ WebSocket 通知配置 ============
# Gateway 地址（用于发送飞书通知）
GATEWAY_HOST=localhost
GATEWAY_PORT=18789

# ============ 通知配置 ============
# 默认通知目标（飞书 open_id）
NOTIFY_TARGET=ou_xxxxxxxxxxxxxxxx

# ============ 身份配置 ============
# clawnode 使用独立身份目录: ~/.clawnode/identity/
# device.json 和 device-auth.json 在该目录下自动管理
# 无需手动配置
