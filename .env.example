# OpenClaw 服务器地址
OPENCLAW_URL=http://localhost:3000

# 节点标识
NODE_ID=node-001

# 节点密钥（用于身份验证，推送模式必需）
NODE_SECRET=your-secret-key

# 运行模式：push（推送）, poll（轮询）, hybrid（混合）
RUN_MODE=hybrid

# 任务轮询间隔（毫秒）- 仅轮询模式需要
POLL_INTERVAL=5000

# 推送模式接收端口 - 仅推送模式需要
RECEIVER_PORT=3000

# Hook 回调服务端口
HOOK_PORT=3001

# 执行超时时间（毫秒）
EXEC_TIMEOUT=300000

# Claude Code 配置
CLAUDE_API_KEY=your-claude-api-key

# 日志级别
LOG_LEVEL=info

# 通知配置（用于发送消息到渠道）
OPENCLAW_BIN=/home/ubuntu/.npm-global/bin/openclaw
NOTIFY_CHANNEL=feishu
NOTIFY_ACCOUNT=manager
NOTIFY_TARGET=ou_f83886ae0d75c6b709967d289d6a46e3

# WebSocket 发送器配置（用于直接向 Gateway 发送消息）
GATEWAY_HOST=localhost
GATEWAY_PORT=18789
DEVICE_TOKEN=your-device-token
DEVICE_ID=your-device-id
PRIVATE_KEY=your-base64url-private-key
PUBLIC_KEY=your-base64url-public-key
